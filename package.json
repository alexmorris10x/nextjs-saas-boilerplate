{
  "name": "nextjs-saas-boilerplate",
  "version": "1.0.0",
  "private": false,
  "description": "Production-ready Next.js SaaS boilerplate with authentication, Stripe billing, and analytics",
  "scripts": {
    "dev": "npm run clean && next dev",
    "build": "next build",
    "test": "npm run ci:smoke",
    "ci:smoke": "node scripts/ci-smoke-guardrails.mjs",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src --ext .ts,.tsx,.js,.jsx",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "start": "next start",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1086.0",
    "@axiomhq/js": "^1.8.0",
    "@axiomhq/logging": "^0.3.0",
    "@axiomhq/nextjs": "^0.3.0",
    "@neondatabase/serverless": "^1.1.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@posthog/nextjs-config": "^1.9.68",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@serwist/next": "^9.5.11",
    "@stripe/react-stripe-js": "^6.7.0",
    "@stripe/stripe-js": "^9.10.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tanstack/query-async-storage-persister": "^5.101.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-persist-client": "^5.101.2",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "axios": "^1.18.1",
    "crisp-sdk-web": "^1.2.0",
    "eslint": "^10.7.0",
    "framer-motion": "^12.42.2",
    "jsonwebtoken": "^9.0.3",
    "localforage": "^1.10.0",
    "lodash": "^4.18.1",
    "lru-cache": "^11.5.2",
    "lucide-react": "^1.24.0",
    "mailgun.js": "^13.3.0",
    "next": "^16.2.10",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.8.16",
    "posthog-js": "^1.400.0",
    "posthog-node": "^5.42.0",
    "postmark": "^5.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-tooltip": "^6.0.8",
    "server-only": "^0.0.1",
    "serwist": "^9.0.10",
    "stripe": "^22.3.1",
    "zod": "^4.3.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.23",
    "@types/node": "^24.2.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.7",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "autoprefixer": "^10.4.21",
    "daisyui": "^5.6.18",
    "eslint-config-next": "^15.5.7",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^7.0.2",
    "eslint-plugin-import": "^2.32.0",
    "postcss": "^8.5.19",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.1.12",
    "typescript": "5.9.2",
    "ws": "^8.21.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexmorris10x/nextjs-saas-boilerplate.git"
  },
  "keywords": [
    "nextjs",
    "saas",
    "boilerplate",
    "stripe",
    "authentication",
    "prisma",
    "tailwindcss"
  ]
}
